{
  "name": "enterprise-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api": "npm -w apps/api",
    "web": "npm -w apps/web",
    "api:dev": "npm -w apps/api run start:dev",
    "web:dev": "npm -w apps/web run dev",
    "api:test": "npm -w apps/api test",
    "web:test": "npm -w apps/web test",
    "postinstall": "node scripts/patch-react-transition-group.js"
  },
  "overrides": {
    "@nestjs/common": "^11.1.12",
    "@nestjs/core": "^11.1.12",
    "rxjs": "7.8.2",
    "sharp": "0.35.1",
    "onnxruntime-node": "1.27.0",
    "@tensorflow/tfjs": "4.22.0",
    "@tensorflow/tfjs-backend-wasm": "4.22.0",
    "@vladmandic/human": "3.3.6",
    "tesseract.js": "7.0.0"
  },
  "dependencies": {
    "ink": "^7.1.0"
  }
}

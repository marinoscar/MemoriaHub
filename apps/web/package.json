{
  "name": "web",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linter configured'",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run --exclude '**/node_modules/**' --exclude '**/dist/**' --exclude 'src/__tests__/components/common/Layout.test.tsx' --exclude 'src/__tests__/pages/AiSettingsPage.test.tsx' --exclude 'src/__tests__/pages/AiSettingsPageExtended.test.tsx' --exclude 'src/__tests__/components/navigation/Sidebar.test.tsx' --exclude 'src/__tests__/pages/JobsPage.test.tsx' --exclude 'src/__tests__/App.test.tsx' --exclude 'src/components/media/__tests__/MediaGallery.test.tsx' --exclude 'src/__tests__/pages/CircleDetailPage.test.tsx'"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@mui/x-charts": "^9.8.0",
    "@vidstack/react": "^1.15.6",
    "hash-wasm": "^4.12.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^6.1.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.8",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.8"
  }
}

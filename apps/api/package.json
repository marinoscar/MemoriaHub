{
  "name": "api",
  "version": "1.0.0",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linter configured'",
    "test": "jest --config ./test/jest.config.js --testPathIgnorePatterns='e2e'",
    "test:all": "jest --config ./test/jest.config.js",
    "test:watch": "jest --config ./test/jest.config.js --watch --testPathIgnorePatterns='e2e'",
    "test:cov": "jest --config ./test/jest.config.js --coverage --testPathIgnorePatterns='e2e'",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand --config ./test/jest.config.js --testPathIgnorePatterns='e2e'",
    "test:e2e": "jest --config ./test/jest.config.js --testRegex '.e2e.spec.ts$'",
    "test:unit": "jest --config ./test/jest.config.js --testPathIgnorePatterns='e2e'",
    "test:ci": "jest --config ./test/jest.config.js --coverage --ci --reporters=default --reporters=jest-junit --testPathIgnorePatterns='e2e'",
    "prisma": "node scripts/prisma-env.js",
    "prisma:generate": "node scripts/prisma-env.js generate",
    "prisma:migrate": "node scripts/prisma-env.js migrate deploy",
    "prisma:migrate:dev": "node scripts/prisma-env.js migrate dev",
    "prisma:studio": "node scripts/prisma-env.js studio",
    "prisma:seed": "node scripts/prisma-env.js db seed",
    "prisma:push": "node scripts/prisma-env.js db push",
    "db:test": "node scripts/test-db-connection.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.975.0",
    "@aws-sdk/lib-storage": "^3.975.0",
    "@aws-sdk/s3-request-presigner": "^3.975.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.0.0",
    "@nestjs/common": "^11.1.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.12",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.12",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/terminus": "^11.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "nestjs-zod": "^5.4.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.x",
    "rxjs": "^7.x",
    "zod": "^4.4.3",
    "exifr": "^7.1.3",
    "sharp": "^0.33.5",
    "fluent-ffmpeg": "^2.1.3",
    "local-reverse-geocoder": "^0.15.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.32",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "jest-mock-extended": "^4.0.1",
    "passport-custom": "^1.x",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.x",
    "typescript": "^6.0.3"
  },
  "prisma": {}
}

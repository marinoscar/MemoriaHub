// MediaSocialStatus tracks per-item detection of social-media re-uploads
// (e.g. TikTok/Instagram/Facebook re-shares) via metadata/filename/OCR heuristics.
// isSocialMedia + platform + detectionMethod + matchedRule mirror the writer's
// decision; media_items.social_media_source (see MediaItem) is the queryable,
// denormalized outcome column used to gate video enrichment.
model MediaSocialStatus {
  id              String                @id @default(uuid()) @db.Uuid
  mediaItemId     String                @unique @map("media_item_id") @db.Uuid
  status          MediaSocialStatusType @default(not_processed)
  isSocialMedia   Boolean               @default(false) @map("is_social_media")
  platform        String? // 'tiktok' | 'instagram' | 'facebook' | 'other'
  detectionMethod String?               @map("detection_method") // 'metadata' | 'filename' | 'ocr'
  confidence      Float?
  matchedRule     String?               @map("matched_rule")
  processedAt     DateTime?             @map("processed_at") @db.Timestamptz
  lastError       String?               @map("last_error")
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  mediaItem MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("media_social_status")
}

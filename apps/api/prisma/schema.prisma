// =============================================================================
// Location Inference
// =============================================================================

enum LocationSuggestionStatus {
  pending
  accepted
  rejected
  auto_applied
  reverted
}

// LocationSuggestion holds one interpolated/nearest-anchor coordinate guess per
// media item that lacks EXIF GPS but has timeline neighbors with coordinates.
// anchorBeforeId / anchorAfterId are intentionally plain nullable UUID columns
// (no Prisma relation, no DB-level FK) — mirrors the media_visual_embedding.circle_id
// "denormalized, no FK" precedent — so deleting the referenced anchor media item
// never blocks or cascades against this row.
model LocationSuggestion {
  id                String                   @id @default(uuid()) @db.Uuid
  mediaItemId       String                   @unique @map("media_item_id") @db.Uuid
  circleId          String                   @map("circle_id") @db.Uuid
  lat               Float
  lng               Float
  confidence        Float
  method            String // 'interpolated' | 'nearest'
  anchorBeforeId    String?                  @map("anchor_before_id") @db.Uuid
  anchorAfterId     String?                  @map("anchor_after_id") @db.Uuid
  gapBeforeSeconds  Int?                     @map("gap_before_seconds")
  gapAfterSeconds   Int?                     @map("gap_after_seconds")
  anchorDistanceKm  Float?                   @map("anchor_distance_km")
  impliedSpeedKmh   Float?                   @map("implied_speed_kmh")
  status            LocationSuggestionStatus @default(pending)
  resolvedById      String?                  @map("resolved_by_id") @db.Uuid
  resolvedAt        DateTime?                @map("resolved_at") @db.Timestamptz
  createdAt         DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime                 @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  mediaItem  MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  circle     Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  resolvedBy User?     @relation("LocationSuggestionResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([circleId, status])
  @@map("location_suggestions")
}


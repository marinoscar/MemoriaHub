{
  "name": "@memoriahub/cli",
  "version": "1.2.13",
  "description": "CLI importer for MemoriaHub — import and sync photo/video folders",
  "type": "module",
  "bin": {
    "memoriahub": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js",
    "test:cov": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js --coverage",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js --ci --testPathIgnorePatterns='test/db/migrations\\.spec\\.ts$' 'test/db/migration-v6\\.spec\\.ts$' 'test/export/scan-export\\.spec\\.ts$' 'test/sync/sync-engine-date-range\\.spec\\.ts$'"
  },
  "dependencies": {
    "@memoriahub/enrichment-compute": "0.1.0",
    "better-sqlite3": "^12.10.0",
    "boxen": "^5.1.2",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "exceljs": "^4.4.0",
    "exifr": "^7.1.3",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ora": "^5.4.1",
    "react": "19",
    "react-reconciler": "^0.33.0"
  },
  "optionalDependencies": {
    "@tensorflow/tfjs": "4.22.0",
    "@tensorflow/tfjs-backend-wasm": "4.22.0",
    "@vladmandic/human": "3.3.6",
    "exiftool-vendored": "35.21.0",
    "onnxruntime-node": "1.27.0",
    "sharp": "0.35.1",
    "tesseract.js": "7.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cli-progress": "^3.11.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/react": "19",
    "ink-testing-library": "^4.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}

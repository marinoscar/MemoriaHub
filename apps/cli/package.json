{
  "name": "@memoriahub/cli",
  "version": "0.1.0",
  "description": "CLI importer for MemoriaHub — import and sync photo/video folders",
  "type": "commonjs",
  "bin": {
    "memoriahub": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest --config jest.config.js",
    "test:cov": "jest --config jest.config.js --coverage"
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "typescript": "^6.0.3"
  }
}

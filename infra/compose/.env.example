# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control
# =============================================================================
#
# -----------------------------------------------------------------------------
# PRODUCTION OVERRIDES (memoriahub.marin.cr)
# -----------------------------------------------------------------------------
# When deploying to production via infra/deploy/install.sh, override the
# development defaults below with the following values in your .env:
#
#   NODE_ENV=production
#   APP_URL=https://memoriahub.marin.cr
#   GOOGLE_CALLBACK_URL=https://memoriahub.marin.cr/api/auth/google/callback
#
#   # Cloud PostgreSQL (SSL required in production)
#   POSTGRES_HOST=<your-cloud-pg-host>
#   POSTGRES_PORT=5432
#   POSTGRES_USER=<user>
#   POSTGRES_PASSWORD=<password>
#   POSTGRES_DB=<dbname>
#   POSTGRES_SSL=true
#
#   # Generate strong secrets: openssl rand -base64 32
#   JWT_SECRET=<min-32-chars>
#   COOKIE_SECRET=<min-32-chars>
#
#   COMPOSE_PROJECT_NAME=memoriahub
#
# See docs/prod-deploy.md for the full production deployment guide.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3535

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# External database connection (DATABASE_URL is constructed from these at runtime)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb
POSTGRES_SSL=false

# -----------------------------------------------------------------------------
# JWT / Session
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a strong secret for production (min 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-min-32-characters-long
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14
COOKIE_SECRET=your-cookie-secret-key-min-32-characters-long

# -----------------------------------------------------------------------------
# OAuth - Google (Required)
# -----------------------------------------------------------------------------
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3535/api/auth/google/callback

# -----------------------------------------------------------------------------
# OAuth - Microsoft (Optional)
# -----------------------------------------------------------------------------
# Get credentials from: https://portal.azure.com
# MICROSOFT_CLIENT_ID=your-microsoft-client-id
# MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# MICROSOFT_CALLBACK_URL=http://localhost:3535/api/auth/microsoft/callback

# -----------------------------------------------------------------------------
# Initial Admin Bootstrap
# -----------------------------------------------------------------------------
# First user to log in with this email will be assigned Admin role
INITIAL_ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Test Authentication (Development/Test Only)
# -----------------------------------------------------------------------------
# Test auth is automatically enabled when NODE_ENV !== 'production'
# This provides /api/auth/test/login endpoint and /testing/login page
# for Playwright E2E testing without requiring real OAuth credentials.
#
# Set to 'false' to explicitly disable test auth in development:
# TEST_AUTH_ENABLED=false
#
# WARNING: Setting TEST_AUTH_ENABLED=true in production will cause the app
# to fail at startup as a safety measure.

# -----------------------------------------------------------------------------
# Device Authorization Flow (RFC 8628)
# -----------------------------------------------------------------------------
# Configuration for device authorization (CLI, Swagger UI, mobile apps)
DEVICE_CODE_EXPIRY_MINUTES=15
DEVICE_CODE_POLL_INTERVAL=5
# Lifetime of access and refresh tokens issued by the device flow (default: 7 days)
DEVICE_TOKEN_EXPIRY_DAYS=7
# Lifetime of PATs issued via device flow for CLI clients (default: 90 days)
DEVICE_PAT_TTL_DAYS=90

# -----------------------------------------------------------------------------
# Observability (OpenTelemetry)
# -----------------------------------------------------------------------------
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=enterprise-app-api
LOG_LEVEL=info
# OTEL_DEBUG=true  # Uncomment to enable OTEL diagnostic logging (development only)

# -----------------------------------------------------------------------------
# Uptrace (when using docker-compose.otel.yml)
# -----------------------------------------------------------------------------
UPTRACE_DSN=http://project1_secret_token@localhost:14317/1

# -----------------------------------------------------------------------------
# ClickHouse (Uptrace storage - typically no changes needed)
# -----------------------------------------------------------------------------
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------
# Storage provider (currently only 's3' is supported)
STORAGE_PROVIDER=s3

# S3 Storage Settings
# For AWS S3: Set region and credentials, leave S3_ENDPOINT empty
# For MinIO/LocalStack: Set S3_ENDPOINT to your local service URL
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=http://localhost:9000  # Optional: for MinIO/LocalStack

# Reverse Geocoding Provider
# offline    — local-reverse-geocoder (GeoNames dataset; no network, GPS stays on-server)
# nominatim  — OSM Nominatim HTTP API (WARNING: sends GPS coordinates off-server)
GEO_PROVIDER=offline
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org  # Optional: override Nominatim endpoint (e.g. private instance)

# Forward Geocoding (place-name search used by the bulk location picker)
# Only the typed query string leaves the server — photo GPS is never sent.
# Disabled by default. Set to true to enable GET /api/media/geo/search.
GEO_FORWARD_SEARCH_ENABLED=false
# Forward geocoding provider: nominatim (default, OSM) or google (Google Maps Geocoding API)
# Google option: requires billing-enabled GCP project; typed address text is sent to Google.
# If GEO_FORWARD_PROVIDER=google but GOOGLE_MAPS_API_KEY is not set, falls back to Nominatim.
GEO_FORWARD_PROVIDER=nominatim
# GOOGLE_MAPS_API_KEY=   # Required when GEO_FORWARD_PROVIDER=google; key is server-side only, never exposed to clients

# Storage Limits and Configuration
MAX_FILE_SIZE=10737418240  # 10GB in bytes
ALLOWED_MIME_TYPES=image/*,application/pdf,video/*
SIGNED_URL_EXPIRY=3600  # Signed URL expiration in seconds (1 hour)
STORAGE_PART_SIZE=10485760  # Multipart upload part size in bytes (10MB)

# Thumbnail generation settings
THUMBNAIL_MAX_DIM=800    # Maximum width and height in pixels (fit: inside, no enlargement)
THUMBNAIL_QUALITY=85     # JPEG quality 1-100

# -----------------------------------------------------------------------------
# Backup / Local-Drive Replication (Admin only)
# -----------------------------------------------------------------------------
# Filesystem path where blobs are replicated by `POST /api/admin/backup`
# The directory will be created if it doesn't exist.
# BACKUP_LOCAL_PATH=/mnt/external-drive/memoriahub-backup

# Storage provider used by the backup job (default: local)
# STORAGE_BACKUP_PROVIDER=local

# -----------------------------------------------------------------------------
# AI Provider Encryption
# -----------------------------------------------------------------------------
# AES-256-GCM key for encrypting AI provider API keys at rest.
# Generate with: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Face Recognition (CompreFace keyless core sidecar)
# -----------------------------------------------------------------------------
# Base URL for the CompreFace core ML engine (keyless — no API key required).
# Default resolves to the compreface-core docker service on the app-network.
# Override to point at a remote or custom deployment.
FACE_COMPREFACE_URL=http://compreface-core:3000
# Face detection job poll interval in milliseconds (Phase 2)
FACE_JOB_POLL_MS=5000
# Cosine similarity threshold for face matching (Phase 3, ArcFace ~0.38)
FACE_MATCH_THRESHOLD=0.38
# Vector backend: 'app' (Float[] in-app cosine) or 'pgvector' (native index)
FACE_VECTOR_BACKEND=app
# Cosine similarity threshold for unknown-face clustering (stricter than FACE_MATCH_THRESHOLD)
FACE_CLUSTER_THRESHOLD=0.45
# Minimum cluster size to create a provisional Person (singletons stay unknown)
FACE_CLUSTER_MIN_SIZE=2
# Global kill-switch for automatic face detection on media upload.
# Set to 'false' to disable auto-enqueue globally (per-circle opt-in still applies when true).
# Default: true
# FACE_AUTO_DETECT=true
AUTO_TAG_ENABLED=true          # Set to false to disable auto-tagging on upload globally (default: true)
# Path where @vladmandic/human model files are stored (bundled in Docker image)
FACE_HUMAN_MODEL_PATH=/app/models/human
# Maximum long-edge pixel size before sending to face detection (caps CompreFace load, keeps AWS Rekognition under 5 MB).
# Default: 2000. Set higher for better accuracy on small faces in wide shots.
FACE_MAX_IMAGE_DIM=2000

# Enrichment Job Queue (generic worker — replaces face-specific FaceJobWorker)
ENRICHMENT_WORKER_ENABLED=true          # Set to 'false' to disable the worker
ENRICHMENT_JOB_POLL_MS=5000            # Poll interval in ms (default: 5000)
ENRICHMENT_WORKER_CONCURRENCY=1        # Concurrent job slots (default: 1)
# Job priority scheme: lower number = higher priority
#   rerun=0   (user-triggered, processed first)
#   upload=10 (auto-enqueued on upload)
#   backfill=100 (background, processed last)
# Legacy FACE_WORKER_ENABLED / FACE_JOB_POLL_MS / FACE_WORKER_CONCURRENCY still honored as fallback

{
  "name": "@memoriahub/enrichment-compute",
  "version": "0.1.0",
  "description": "Shared PURE enrichment compute (image prep, CLIP embedding, dHash, node result DTOs) imported identically by apps/api and apps/cli so node-computed vectors are numerically identical to server-computed ones (distributed-nodes spec §7)",
  "private": true,
  "type": "module",
  "main": "./dist/cjs/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./image": {
      "types": "./dist/types/image/index.d.ts",
      "import": "./dist/esm/image/index.js",
      "require": "./dist/cjs/image/index.js"
    },
    "./ai": {
      "types": "./dist/types/ai/index.d.ts",
      "import": "./dist/esm/ai/index.js",
      "require": "./dist/cjs/ai/index.js"
    },
    "./geo": {
      "types": "./dist/types/geo/index.d.ts",
      "import": "./dist/esm/geo/index.js",
      "require": "./dist/cjs/geo/index.js"
    },
    "./rate-limit": {
      "types": "./dist/types/rate-limit/index.d.ts",
      "import": "./dist/esm/rate-limit/index.js",
      "require": "./dist/cjs/rate-limit/index.js"
    },
    "./clip": {
      "types": "./dist/types/clip/index.d.ts",
      "import": "./dist/esm/clip/index.js",
      "require": "./dist/cjs/clip/index.js"
    },
    "./dhash": {
      "types": "./dist/types/dhash/index.d.ts",
      "import": "./dist/esm/dhash/index.js",
      "require": "./dist/cjs/dhash/index.js"
    },
    "./dto": {
      "types": "./dist/types/dto/index.d.ts",
      "import": "./dist/esm/dto/index.js",
      "require": "./dist/cjs/dto/index.js"
    },
    "./face": {
      "types": "./dist/types/face/index.d.ts",
      "import": "./dist/esm/face/index.js",
      "require": "./dist/cjs/face/index.js"
    },
    "./face-compreface": {
      "types": "./dist/types/face-compreface/index.d.ts",
      "import": "./dist/esm/face-compreface/index.js",
      "require": "./dist/cjs/face-compreface/index.js"
    },
    "./face-video": {
      "types": "./dist/types/face-video/index.d.ts",
      "import": "./dist/esm/face-video/index.js",
      "require": "./dist/cjs/face-video/index.js"
    },
    "./ocr": {
      "types": "./dist/types/ocr/index.d.ts",
      "import": "./dist/esm/ocr/index.js",
      "require": "./dist/cjs/ocr/index.js"
    },
    "./metadata": {
      "types": "./dist/types/metadata/index.d.ts",
      "import": "./dist/esm/metadata/index.js",
      "require": "./dist/cjs/metadata/index.js"
    },
    "./social": {
      "types": "./dist/types/social/index.d.ts",
      "import": "./dist/esm/social/index.js",
      "require": "./dist/cjs/social/index.js"
    },
    "./video": {
      "types": "./dist/types/video/index.d.ts",
      "import": "./dist/esm/video/index.js",
      "require": "./dist/cjs/video/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node ./scripts/write-dist-stubs.mjs",
    "typecheck": "tsc -p tsconfig.esm.json --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.111.0",
    "exifr": "7.1.3",
    "fluent-ffmpeg": "2.1.3",
    "onnxruntime-node": "1.27.0",
    "openai": "6.46.0",
    "sharp": "0.35.3",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@tensorflow/tfjs": "4.22.0",
    "@tensorflow/tfjs-backend-wasm": "4.22.0",
    "@vladmandic/human": "3.3.6",
    "tesseract.js": "7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^6.0.3"
  }
}

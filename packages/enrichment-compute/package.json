{
  "name": "@memoriahub/enrichment-compute",
  "version": "0.1.0",
  "description": "Shared PURE enrichment compute (image prep, CLIP embedding, dHash, node result DTOs) imported identically by apps/api and apps/cli so node-computed vectors are numerically identical to server-computed ones (distributed-nodes spec §7)",
  "private": true,
  "type": "module",
  "main": "./dist/cjs/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./image": {
      "types": "./dist/types/image/index.d.ts",
      "import": "./dist/esm/image/index.js",
      "require": "./dist/cjs/image/index.js"
    },
    "./clip": {
      "types": "./dist/types/clip/index.d.ts",
      "import": "./dist/esm/clip/index.js",
      "require": "./dist/cjs/clip/index.js"
    },
    "./dhash": {
      "types": "./dist/types/dhash/index.d.ts",
      "import": "./dist/esm/dhash/index.js",
      "require": "./dist/cjs/dhash/index.js"
    },
    "./dto": {
      "types": "./dist/types/dto/index.d.ts",
      "import": "./dist/esm/dto/index.js",
      "require": "./dist/cjs/dto/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node ./scripts/write-dist-stubs.mjs",
    "typecheck": "tsc -p tsconfig.esm.json --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "onnxruntime-node": "1.27.0",
    "sharp": "0.35.1",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@tensorflow/tfjs": "4.22.0",
    "@tensorflow/tfjs-backend-wasm": "4.22.0",
    "@vladmandic/human": "3.3.6",
    "tesseract.js": "7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^6.0.3"
  }
}

# =============================================================================
# memoriahub-worker bundle environment — copy to .env.worker and edit
# =============================================================================
# Usage:
#   cp .env.worker.example .env.worker
#   # edit MEMORIAHUB_URL + MEMORIAHUB_TOKEN (+ MEMORIAHUB_NODE_NAME per host)
#   docker compose -f docker-compose.worker.yml --env-file .env.worker up -d
# =============================================================================

# --- Required ---------------------------------------------------------------
# Base URL of your MemoriaHub API (the control plane the worker talks to over
# HTTPS — the worker never connects to the database).
MEMORIAHUB_URL=https://memoria.example.com

# Node credential. Preferred: a durable node credential (nod_...) minted in the
# admin UI at /admin/settings/nodes (least-privilege — valid only on node
# endpoints, never expires, individually revocable). A PAT (pat_...) also works.
MEMORIAHUB_TOKEN=nod_replace_me

# --- Identity ---------------------------------------------------------------
# Base name for this host's worker node(s). Use a distinct value per machine so
# nodes on different hosts don't collide (register-or-reattach is keyed by
# owner+name). Each replica re-attaches to its record on restart.
MEMORIAHUB_NODE_NAME=worker-laptop-a

# --- Tuning -----------------------------------------------------------------
# Jobs each worker replica runs concurrently. Keep low (1-2) for AI/face-bound
# work on memory-constrained hosts; raise on beefier machines.
MEMORIAHUB_CONCURRENCY=2

# CompreFace uWSGI processes. Rule of thumb: cores-2, capped around 6.
COMPREFACE_PROCESSES=2

# Published worker image tag. Pin to a version (e.g. cli-1.2.4 or a semver tag)
# for reproducibility; 'latest' tracks the newest build.
WORKER_VERSION=latest

# SIGTERM drain budget on `docker compose down`/stop. A job killed past this is
# requeued by the server lease reaper, so it need not cover long video jobs.
WORKER_STOP_GRACE=180s
